{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "5a506515d08842bd9f50f00781dbdfa9",
    "m_Group": {
        "m_Id": "37d9b27cd045407092beb941f27cae9a"
    },
    "m_Name": "MyNoise3D (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 1725.3331298828125,
            "y": 6146.666015625,
            "width": 221.3333740234375,
            "height": 120.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "635cda819ca84b9087b540de736aa119"
        },
        {
            "m_Id": "40ba47ebc5934ba1a84bc911e39858fe"
        },
        {
            "m_Id": "053533adbcdd4df38afb86dfc85b0925"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "MyNoise3D",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float3 p = Pos * Scale;\nfloat3 i = floor(p);\nfloat3 f = frac(p);\nf = f * f * (3.0 - 2.0 * f);\nfloat n = i.x + i.y * 157.0 + 113.0 * i.z;\nfloat4 v = float4(n, n + 1.0, n + 157.0, n + 158.0);\nfloat4 v1 = v + 113.0;\nfloat4 r = frac(sin(v) * 43758.5453123);\nfloat4 r1 = frac(sin(v1) * 43758.5453123);\nfloat a = lerp(lerp(r.x, r.y, f.x), lerp(r.z, r.w, f.x), f.y);\nfloat b = lerp(lerp(r1.x, r1.y, f.x), lerp(r1.z, r1.w, f.x), f.y);\nOut = lerp(a, b, f.z);\n"
}

